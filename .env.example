# Copie este arquivo para .env e ajuste os valores:
#   cp .env.example .env

# PostgreSQL
POSTGRES_DB=sre_dashboard
POSTGRES_USER=sre_user
# Troque por uma senha forte antes do deploy!
POSTGRES_PASSWORD=troque-esta-senha

# Backend
# DEVELOPMENT, HOMOLOGATION ou PRODUCTION
APP_ENVIRONMENT=PRODUCTION
# Origens permitidas para CORS (separadas por vírgula).
# Em produção com Nginx como proxy, o mesmo host já atende o frontend.
CORS_ALLOWED_ORIGINS=http://localhost

# Grafana (opcional, perfil "grafana")
GRAFANA_ADMIN_PASSWORD=admin
